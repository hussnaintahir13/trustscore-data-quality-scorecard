{
  "compilerOptions": {
    "allowJs": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "target": "es6",
    "module": "es6",
    "moduleResolution": "node",
    "removeComments": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "lib": ["es2015", "es2016", "es2017", "dom", "es2017.object"],
    "outDir": ".tmp/build"
  },
  "include": ["src/**/*.ts"]
}
